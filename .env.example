AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=ap-northeast-1
BEDROCK_MODEL=jp.anthropic.claude-sonnet-4-6

# DB接続URL（開発: SQLite、本番: PostgreSQL推奨）
# SQLite:     sqlite:///./data/proofreader.db
# PostgreSQL: postgresql://user:pass@host:5432/proofreader
# MySQL:      mysql+pymysql://user:pass@host/proofreader
DATABASE_URL=sqlite:///./data/proofreader.db
