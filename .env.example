AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=ap-northeast-1
BEDROCK_MODEL=jp.anthropic.claude-sonnet-4-6

# DB接続URL（Docker起動時は docker-compose.yml 側で自動設定されるので空でOK）
# ローカル開発でDockerを使わない場合:
#   SQLite:     sqlite:///./data/proofreader.db
#   PostgreSQL: postgresql+psycopg2://user:pass@host:5432/proofreader
# DATABASE_URL=sqlite:///./data/proofreader.db

# PostgreSQL コンテナのアカウント情報（任意。省略時は proofreader/proofreader）
# POSTGRES_USER=proofreader
# POSTGRES_PASSWORD=proofreader
# POSTGRES_DB=proofreader
